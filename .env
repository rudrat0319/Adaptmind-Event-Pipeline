# Database Configuration
DATABASE_URL=postgres://postgres.[YOUR_ID]:[PASSWORD]@aws-0-pooler.supabase.com:6543/postgres

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=adaptmind.events
# n8n Webhook Configuration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/mission-complete
N8N_WEBHOOK_SECRET=your-webhook-secret-here

# n8n Webhook Configuration
N8N_WEBHOOK_URL=https://webhook.site/your-unique-id
N8N_WEBHOOK_SECRET=any-random-string-here

# Retry Configuration
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_BASE_DELAY_MS=1000

# Server Configuration
PORT=3000
NODE_ENV=development
